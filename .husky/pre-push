#!/bin/sh

if ! docker compose ps laravel.test --status running 2>/dev/null | grep -q "laravel.test"; then
  echo ""
  echo "❌ Docker laravel.test service is not running."
  echo "   Start it with: docker compose up -d"
  echo ""
  exit 1
fi

echo "🔍 Running PHPStan..."
docker compose exec -T laravel.test php vendor/bin/phpstan analyse --memory-limit=2G --no-progress
if [ $? -ne 0 ]; then
  echo "❌ PHPStan failed"
  exit 1
fi

echo "🧪 Running tests..."
docker compose exec -T laravel.test php vendor/bin/pest --colors=always --compact
if [ $? -ne 0 ]; then
  echo "❌ Tests failed"
  exit 1
fi

echo "✅ All pre-push checks passed"
